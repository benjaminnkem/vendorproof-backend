// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int    @id @default(autoincrement())
  email     String @unique
  firstName String
  lastName  String

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]
  userAuth   UserAuth?

  @@index([email], name: "idx_user_email")
  @@map("users")
}

model UserAuth {
  id     Int @id @default(autoincrement())
  userId Int @unique

  password                 String?
  passwordHistory          String[]  @default([])
  loginRequestCount        Int       @default(0)
  isLocked                 Boolean   @default(false)
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([passwordResetToken], name: "idx_password_reset_token")
  @@map("user_auths")
}

model Business {
  id                     Int      @id @default(autoincrement())
  ownerId                Int?
  name                   String
  description            String?
  logo                   String?
  showCaseImages         String[] @default([])
  email                  String?
  phoneNumber            String?
  alternativePhoneNumber String?
  category               String?
  slug                   String   @unique

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  businessKYCs BusinessKYC[]

  trustScore          Float               @default(0)
  paymentLink         String?
  qrCodeUrl           String?
  trustScoreHistories TrustScoreHistory[]
  trustEntries        TrustEntry[]
  socials             Social[]
  owner               User?               @relation(fields: [ownerId], references: [id])
  tier                Tier?               @relation(fields: [tierId], references: [id])

  kycStatus   KycStatus     @default(PENDING)
  bankDetails BankDetails[]
  tierId      Int?

  @@index([ownerId], name: "idx_business_owner_id")
  @@index([name], name: "idx_business_name")
  @@map("businesses")
}

model BankDetails {
  id            Int     @id @default(autoincrement())
  businessId    Int
  bankName      String
  accountNumber String
  accountName   String
  isPrimary     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@map("bank_details")
}

model Social {
  id         Int            @id @default(autoincrement())
  businessId Int
  platform   SocialPlatform
  url        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@map("socials")
}

enum SocialPlatform {
  FACEBOOK
  TWITTER
  LINKEDIN
  INSTAGRAM
  TIKTOK
  YOUTUBE
  WEBSITE
  OTHER
}

model BusinessKYC {
  id               Int              @id @default(autoincrement())
  businessId       Int
  url              String?
  verificationType VerificationType
  status           KycStatus        @default(PENDING)
  score            Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([verificationType], name: "idx_verification_type")
  @@map("business_kycs")
}

enum VerificationType {
  CAC
  NIN
  UTILITY_BILL
  SELFIE
  TIN
  OTHER
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

model TrustScoreHistory {
  id         Int      @id @default(autoincrement())
  businessId Int
  score      Float
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@map("trust_score_histories")
}

model TrustEntry {
  id             Int     @id @default(autoincrement())
  businessId     Int
  rating         Int?
  comment        String?
  reason         String?
  scoreIncrement Float
  scoreBefore    Float
  scoreAfter     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@map("trust_entries")
}

model Tier {
  id          Int       @id @default(autoincrement())
  name        TierNames @unique
  description String?
  minScore    Float
  maxScore    Float?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]

  @@map("tiers")
}

enum TierNames {
  UNVERIFIED
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}
