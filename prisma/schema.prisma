// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int     @id @default(autoincrement())
  email       String?
  firstName   String
  lastName    String
  phoneNumber String  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business?
  userAuth UserAuth?

  kycIdDocumentUrl String?
  kycSelfieUrl     String?
  businessId       Int?    @unique

  @@index([email], name: "idx_user_email")
  @@map("users")
}

model UserAuth {
  id     Int @id @default(autoincrement())
  userId Int @unique

  password                 String?
  passwordHistory          String[]  @default([])
  loginRequestCount        Int       @default(0)
  isLocked                 Boolean   @default(false)
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?

  accessToken String?
  lastLoginAt DateTime?

  loginOtp          String?
  loginOtpExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authStep Int? @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([passwordResetToken], name: "idx_password_reset_token")
  @@map("user_auths")
}

model Business {
  id                        Int      @id @default(autoincrement())
  ownerId                   Int      @unique
  name                      String
  description               String?
  logo                      String?
  showCaseImages            String[] @default([])
  email                     String?
  phoneNumber               String?
  alternativePhoneNumber    String?
  category                  String?
  slug                      String   @unique
  nin                       String?
  kycBusinessCacDocumentUrl String?
  kycBusinessTinNumber      String?
  isRegistered              Boolean  @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  businessKYCs BusinessKYC[]

  trustScore          Float               @default(0)
  paymentLink         String?
  qrCodeUrl           String?
  trustScoreHistories TrustScoreHistory[]
  trustEntries        TrustEntry[]
  socials             Social[]
  owner               User                @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tier                Tier?               @relation("TierBusinesses", fields: [tierId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  kycStatus   KycStatus     @default(PENDING)
  bankDetails BankDetails[]
  tierId      Int?

  services     Service[]
  paymentLinks PaymentLink[]
  payments     Payment[]

  @@index([ownerId], name: "idx_business_owner_id")
  @@index([name], name: "idx_business_name")
  @@map("businesses")
}

model BankDetails {
  id            Int     @id @default(autoincrement())
  businessId    Int
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  isPrimary     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  services Service[]

  @@map("bank_details")
}

model Social {
  id         Int            @id @default(autoincrement())
  businessId Int
  platform   SocialPlatform
  url        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("socials")
}

enum SocialPlatform {
  FACEBOOK
  TWITTER
  LINKEDIN
  INSTAGRAM
  TIKTOK
  YOUTUBE
  WEBSITE
  OTHER
}

model BusinessKYC {
  id               Int              @id @default(autoincrement())
  businessId       Int?
  url              String?
  verificationType VerificationType
  status           KycStatus        @default(PENDING)
  score            Float?
  reason           String?
  metadata         Json?
  externalRef      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([businessId], name: "idx_business_kyc_business_id")
  @@index([status], name: "idx_business_kyc_status")
  @@index([verificationType], name: "idx_verification_type")
  @@map("business_kycs")
}

enum VerificationType {
  CAC
  NIN
  UTILITY_BILL
  SELFIE
  TIN
  OTHER
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

model TrustScoreHistory {
  id         Int      @id @default(autoincrement())
  businessId Int
  score      Float
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("trust_score_histories")
}

model TrustEntry {
  id             Int     @id @default(autoincrement())
  businessId     Int
  rating         Int?
  comment        String?
  reason         String?
  scoreIncrement Float
  scoreBefore    Float
  scoreAfter     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("trust_entries")
}

model Tier {
  id          Int       @id @default(autoincrement())
  name        TierNames @unique
  description String?
  minScore    Float
  maxScore    Float?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[] @relation("TierBusinesses")

  @@map("tiers")
}

enum TierNames {
  UNVERIFIED
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

model Service {
  id            Int     @id @default(autoincrement())
  businessId    Int
  name          String
  description   String?
  amount        Float?
  bankDetailsId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bankDetails BankDetails? @relation(fields: [bankDetailsId], references: [id], onDelete: SetNull)
  paymentLink PaymentLink?

  @@map("services")
}

model PaymentLink {
  id          Int             @id @default(autoincrement())
  businessId  Int
  token       String          @unique
  type        PaymentLinkType @default(GENERIC)
  amount      Float?
  description String?
  serviceId   Int?            @unique
  isOneTime   Boolean         @default(false)
  isUsed      Boolean         @default(false)
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service?  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([token], name: "idx_payment_link_token")
  @@map("payment_links")
}

model Payment {
  id                   Int           @id @default(autoincrement())
  paymentLinkId        Int
  businessId           Int
  buyerName            String
  buyerEmail           String
  amount               Float
  isServiceRendered    Boolean       @default(false)
  ratingToken          String?       @unique
  ratingTokenExpiresAt DateTime?
  status               PaymentStatus @default(PENDING)
  squadRef             String?       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentLink PaymentLink    @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
  business    Business       @relation(fields: [businessId], references: [id])
  rating      PaymentRating?

  @@index([ratingToken], name: "idx_payment_rating_token")
  @@map("payments")
}

model PaymentRating {
  id        Int     @id @default(autoincrement())
  paymentId Int     @unique
  rating    Int
  comment   String?

  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_ratings")
}

enum PaymentLinkType {
  GENERIC
  SERVICE
  QUICK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
