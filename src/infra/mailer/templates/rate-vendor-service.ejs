<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rate Your Vendor</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background: #f6f8fc;
      font-family: Arial, sans-serif;
      color: #17212f;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="padding: 24px 12px"
    >
      <tr>
        <td align="center">
          <table
            role="presentation"
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="
              max-width: 620px;
              background: #ffffff;
              border-radius: 12px;
              padding: 28px 24px;
              border: 1px solid #e8edf5;
            "
          >
            <tr>
              <td>
                <h2 style="margin: 0 0 16px 0; font-size: 24px; color: #101828">
                  Thanks for your payment, <%= buyerName %>!
                </h2>
                <p
                  style="
                    margin: 0 0 14px 0;
                    font-size: 15px;
                    line-height: 1.6;
                    color: #344054;
                  "
                >
                  You paid <strong><%= amountPaid %></strong> to
                  <strong><%= vendorName %></strong>.
                </p>
                <p
                  style="
                    margin: 0 0 14px 0;
                    font-size: 15px;
                    line-height: 1.6;
                    color: #344054;
                  "
                >
                  You can rate this vendor after the service has been rendered.
                </p>
                <p
                  style="
                    margin: 0 0 22px 0;
                    font-size: 15px;
                    line-height: 1.6;
                    color: #344054;
                  "
                >
                  Once the service is completed, use the link below to submit
                  your rating:
                </p>
                <p style="margin: 0 0 24px 0">
                  <a
                    href="<%= rateUrl %>"
                    style="
                      display: inline-block;
                      background: #0f766e;
                      color: #ffffff;
                      text-decoration: none;
                      font-size: 14px;
                      font-weight: 600;
                      padding: 12px 18px;
                      border-radius: 8px;
                    "
                  >
                    Rate Vendor
                  </a>
                </p>
                <p
                  style="
                    margin: 0;
                    font-size: 13px;
                    line-height: 1.6;
                    color: #667085;
                    word-break: break-all;
                  "
                >
                  If the button does not work, copy and paste this URL into your
                  browser:<br />
                  <a
                    href="<%= rateUrl %>"
                    style="color: #0f766e; text-decoration: underline"
                    ><%= rateUrl %></a
                  >
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
